# PostgreSQL (default matches docker-compose.yml)
DATABASE_URL=jdbc:postgresql://localhost:5432/vibehunt
DATABASE_USER=vibehunt
DATABASE_PASSWORD=vibehunt

# Web client origin (Compose dev server)
WEB_ORIGIN=http://localhost:8081
FRONTEND_URL=http://localhost:8081

# Session cookie
SESSION_COOKIE_NAME=vibehunt_session
SESSION_DAYS=30
OAUTH_DEV_MOCK=true
SERVER_PUBLIC_URL=http://localhost:8080

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match the authorized redirect URI in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/oauth/callback/google

# Apple Sign In (https://developer.apple.com/account/resources/identifiers/list/serviceId)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# PEM private key (.p8); use \n for newlines in .env files
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=http://localhost:8080/api/auth/oauth/callback/apple
